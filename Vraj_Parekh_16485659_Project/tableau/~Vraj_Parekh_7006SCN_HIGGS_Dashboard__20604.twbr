    <dashboard enable-sort-zone-taborder='true' name='Scalability &amp; Cost Analysis'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='20'>Scalability &amp; Cost Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97858' id='25' param='vert' type-v2='layout-flow' w='99018' x='491' y='1071'>
            <zone h='6426' id='26' type-v2='title' w='99018' x='491' y='1071'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='91432' id='23' type-v2='layout-basic' w='99018' x='491' y='7497'>
              <zone forceUpdate='true' h='45714' id='1' type-v2='text' w='99018' x='491' y='7497'>
                <formatted-text>
                  <run bold='true' fontcolor='#f28e2b' fontname='Benton Sans Book' fontsize='12'>Infrastructure &amp; Constraints</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Env:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Google Colab (Single-Node) | 2 Cores | 12GB RAM</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Challenge:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> 7.48 GB (11M+ Rows) causes immediate </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>OOM Failure</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>.</run>
                  <run>Æ&#10;&#10;</run>
                  <run bold='true' fontcolor='#f28e2b' fontname='Benton Sans Book' fontsize='12'>Scalability Strategy</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Solution:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Implemented </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>5% Stratified Pushdown Sample</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> to simulate enterprise constraints.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Result:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Reduced processing from System Failure to </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>4 mins</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> while maintaining statistical validity.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#f28e2b' fontname='Benton Sans Book' fontsize='12'>Data Engineering &amp; Optimization</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Storage:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Utilized </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Parquet</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> format for 3x faster I/O &amp; Tableau extracts.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Scaling:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Æ </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>RDD Partitioning (200)</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> ensures pipeline is Cluster-Ready for AWS/Databricks.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Metrics:</run>
                  <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> Demonstrated </run>
                  <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Strong Scaling</run>
